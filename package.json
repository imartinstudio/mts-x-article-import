{
  "name": "mts-x-article-import",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Standalone Chrome MV3 extension to import Markdown into X Articles draft editor. 将本地 Markdown 导入 X Articles 草稿编辑器（独立项目）。",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imartinstudio/mts-x-article-import.git"
  },
  "homepage": "https://github.com/imartinstudio/mts-x-article-import#readme",
  "bugs": {
    "url": "https://github.com/imartinstudio/mts-x-article-import/issues"
  },
  "scripts": {
    "build": "node ./build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:smoke": "vitest run tests/smoke.test.ts && node ./scripts/dist-smoke.mjs",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "mermaid": "^11.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.304",
    "@types/node": "^26.1.0",
    "esbuild": "^0.25.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
